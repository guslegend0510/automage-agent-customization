{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automage.local/schemas/schema_v1_incident.json",
  "title": "AutoMage-2 MVP Incident Schema",
  "description": "schema_v1_incident：异常、风险、阻塞、权限问题和工作流失败的统一上报契约。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "idRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    }
  },
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "schema_v1_incident"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "incident_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "org_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "department_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "incident_title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "incident_type": {
      "type": "string",
      "enum": [
        "data_missing",
        "schema_invalid",
        "task_blocked",
        "task_overdue",
        "permission_issue",
        "decision_pending",
        "decision_conflict",
        "workflow_failed",
        "system_error",
        "business_risk",
        "cross_department_dependency",
        "other"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "triaged",
        "assigned",
        "in_progress",
        "waiting_decision",
        "waiting_external",
        "resolved",
        "closed",
        "cancelled",
        "reopened"
      ]
    },
    "source_type": {
      "type": "string",
      "enum": [
        "staff_report",
        "manager_summary",
        "executive_decision",
        "task",
        "schema_validation",
        "permission_check",
        "system",
        "manual",
        "other"
      ]
    },
    "source_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "source_record_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "source_summary_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "related_task_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "related_decision_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "reporter_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "owner_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "owner_node_id": {
      "type": "string"
    },
    "need_escalation": {
      "type": "boolean"
    },
    "escalation_level": {
      "type": "string",
      "enum": [
        "manager",
        "executive",
        "offline_meeting",
        "external"
      ]
    },
    "attempted_solution": {
      "type": "string"
    },
    "suggested_action": {
      "type": "string"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    },
    "closed_at": {
      "type": "string",
      "format": "date-time"
    },
    "close_reason": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "org_id",
    "incident_title",
    "description",
    "incident_type",
    "severity",
    "status",
    "source_type",
    "source_id",
    "need_escalation"
  ]
}
