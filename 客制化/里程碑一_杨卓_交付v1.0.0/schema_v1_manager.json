{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automage.local/schemas/schema_v1_manager.json",
  "title": "AutoMage-2 MVP Manager Summary Schema",
  "description": "schema_v1_manager：Manager Agent 部门汇总输出契约。用于部门日报、风险识别、上推老板决策和任务调整。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "idRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confirm_status": {
          "type": "string",
          "enum": [
            "draft",
            "pending",
            "confirmed",
            "rejected",
            "revoked"
          ],
          "description": "人工确认状态"
        },
        "signed_by": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "signed_by_role": {
          "type": "string"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature_method": {
          "type": "string",
          "enum": [
            "manual_confirm",
            "im_confirm",
            "web_confirm",
            "api_confirm",
            "system"
          ]
        },
        "payload_hash": {
          "type": "string",
          "minLength": 1
        },
        "signature_value": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      },
      "required": [
        "confirm_status",
        "signed_by",
        "signed_at",
        "signature_method",
        "payload_hash"
      ]
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "risk_title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "source_type": {
          "type": "string"
        },
        "source_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "owner_user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "suggested_action": {
          "type": "string"
        },
        "need_escalation": {
          "type": "boolean"
        }
      },
      "required": [
        "risk_title",
        "severity"
      ]
    },
    "highlightStaff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "display_name": {
          "type": "string"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_record_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        }
      },
      "required": [
        "user_id",
        "reason"
      ]
    },
    "blockedItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blocked_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "owner_user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "source_record_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        },
        "need_executive_decision": {
          "type": "boolean"
        },
        "suggested_action": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "severity"
      ]
    },
    "decisionItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "decision_title": {
          "type": "string",
          "minLength": 1
        },
        "decision_level": {
          "type": "string",
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3",
            "L4"
          ]
        },
        "background": {
          "type": "string"
        },
        "handled_by": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "result": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "pending",
            "confirmed",
            "rejected",
            "executed",
            "cancelled"
          ]
        },
        "source_record_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        }
      },
      "required": [
        "decision_title",
        "decision_level",
        "status"
      ]
    },
    "executiveDecisionCandidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "decision_title": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "string",
          "minLength": 1
        },
        "reason_to_escalate": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "option_a": {
          "type": "object",
          "additionalProperties": true
        },
        "option_b": {
          "type": "object",
          "additionalProperties": true
        },
        "recommended_option": {
          "type": "string"
        },
        "expected_impact": {
          "type": "object",
          "additionalProperties": true
        },
        "source_record_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        }
      },
      "required": [
        "decision_title",
        "background",
        "risk_level"
      ]
    },
    "adjustmentItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adjustment_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "target_user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "target_role": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "expected_output": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "priority"
      ]
    }
  },
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "schema_v1_manager"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "org_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "dept_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "manager_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "manager_node_id": {
      "type": "string",
      "minLength": 1
    },
    "summary_date": {
      "type": "string",
      "format": "date"
    },
    "staff_report_count": {
      "type": "integer",
      "minimum": 0
    },
    "missing_report_count": {
      "type": "integer",
      "minimum": 0
    },
    "missing_staff_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "overall_health": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red"
      ]
    },
    "aggregated_summary": {
      "type": "string",
      "minLength": 1
    },
    "top_3_risks": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "workforce_efficiency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "explanation": {
          "type": "string"
        }
      }
    },
    "pending_approvals": {
      "type": "integer",
      "minimum": 0
    },
    "highlight_staff": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/highlightStaff"
      }
    },
    "blocked_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blockedItem"
      }
    },
    "manager_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionItem"
      }
    },
    "need_executive_decision": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/executiveDecisionCandidate"
      }
    },
    "next_day_adjustment": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adjustmentItem"
      }
    },
    "source_record_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "source_task_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "source_incident_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "timestamp",
    "org_id",
    "dept_id",
    "manager_user_id",
    "manager_node_id",
    "summary_date",
    "staff_report_count",
    "missing_report_count",
    "overall_health",
    "aggregated_summary",
    "top_3_risks",
    "pending_approvals",
    "source_record_ids",
    "signature"
  ]
}
