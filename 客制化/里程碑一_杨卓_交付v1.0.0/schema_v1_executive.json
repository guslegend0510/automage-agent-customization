{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automage.local/schemas/schema_v1_executive.json",
  "title": "AutoMage-2 MVP Executive Decision Schema",
  "description": "schema_v1_executive：Executive Agent / Dream 生成的老板决策卡片输出契约。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "idRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confirm_status": {
          "type": "string",
          "enum": [
            "draft",
            "pending",
            "confirmed",
            "rejected",
            "revoked"
          ],
          "description": "人工确认状态"
        },
        "signed_by": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "signed_by_role": {
          "type": "string"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature_method": {
          "type": "string",
          "enum": [
            "manual_confirm",
            "im_confirm",
            "web_confirm",
            "api_confirm",
            "system"
          ]
        },
        "payload_hash": {
          "type": "string",
          "minLength": 1
        },
        "signature_value": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      },
      "required": [
        "confirm_status",
        "signed_by",
        "signed_at",
        "signature_method",
        "payload_hash"
      ]
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "risk_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "risk_title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "source_type": {
          "type": "string"
        },
        "source_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "owner_user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "suggested_action": {
          "type": "string"
        },
        "need_escalation": {
          "type": "boolean"
        }
      },
      "required": [
        "risk_title",
        "severity"
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "option_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "pros": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimated_cost": {
          "type": "number",
          "minimum": 0
        },
        "estimated_duration": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      },
      "required": [
        "option_id",
        "title",
        "description"
      ]
    },
    "decisionItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "decision_title": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "string",
          "minLength": 1
        },
        "decision_level": {
          "type": "string",
          "enum": [
            "L2",
            "L3",
            "L4"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "recommended_option": {
          "type": "string"
        },
        "reasoning_summary": {
          "type": "string"
        },
        "expected_impact": {
          "type": "object",
          "additionalProperties": true
        },
        "source_summary_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        },
        "source_incident_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        }
      },
      "required": [
        "decision_title",
        "background",
        "decision_level",
        "risk_level",
        "options"
      ]
    },
    "generatedTask": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_title": {
          "type": "string",
          "minLength": 1
        },
        "task_description": {
          "type": "string",
          "minLength": 1
        },
        "assignee_user_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "assignee_role": {
          "type": "string"
        },
        "department_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "due_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_decision_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "confirm_required": {
          "type": "boolean"
        }
      },
      "required": [
        "task_title",
        "task_description",
        "priority",
        "confirm_required"
      ]
    }
  },
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "schema_v1_executive"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "org_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "executive_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "executive_node_id": {
      "type": "string",
      "minLength": 1
    },
    "summary_date": {
      "type": "string",
      "format": "date"
    },
    "business_summary": {
      "type": "string",
      "minLength": 1
    },
    "key_risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "decision_required": {
      "type": "boolean"
    },
    "decision_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decisionItem"
      }
    },
    "option_a": {
      "$ref": "#/$defs/option"
    },
    "option_b": {
      "$ref": "#/$defs/option"
    },
    "recommended_option": {
      "type": "string"
    },
    "reasoning_summary": {
      "type": "string"
    },
    "expected_impact": {
      "type": "object",
      "additionalProperties": true
    },
    "generated_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/generatedTask"
      }
    },
    "source_summary_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "source_decision_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "source_incident_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "human_confirm_status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "confirmed",
        "rejected",
        "need_more_info",
        "timeout"
      ]
    },
    "confirmed_by": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "confirmed_at": {
      "type": "string",
      "format": "date-time"
    },
    "confirmed_option": {
      "type": "string"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "timestamp",
    "org_id",
    "executive_user_id",
    "executive_node_id",
    "summary_date",
    "business_summary",
    "key_risks",
    "decision_required",
    "source_summary_ids",
    "human_confirm_status"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "decision_required": {
            "const": true
          }
        },
        "required": [
          "decision_required"
        ]
      },
      "then": {
        "required": [
          "decision_items"
        ],
        "properties": {
          "decision_items": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
