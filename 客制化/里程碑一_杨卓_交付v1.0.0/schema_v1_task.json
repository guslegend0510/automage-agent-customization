{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automage.local/schemas/schema_v1_task.json",
  "title": "AutoMage-2 MVP Task Schema",
  "description": "schema_v1_task：老板确认或 Manager 权限内决策后生成的任务下发契约。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "idRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "document",
            "code",
            "image",
            "link",
            "file",
            "table",
            "diagram",
            "prompt",
            "context",
            "config",
            "other"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "mime_type": {
          "type": "string"
        },
        "storage_type": {
          "type": "string",
          "enum": [
            "url",
            "file",
            "object_storage",
            "local_path",
            "text"
          ]
        },
        "version": {
          "type": "string"
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "artifact_type",
        "title"
      ]
    }
  },
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "schema_v1_task"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "task_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "org_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "department_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "task_title": {
      "type": "string",
      "minLength": 1
    },
    "task_description": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "staff_report",
        "manager_summary",
        "executive_decision",
        "incident",
        "manual",
        "system",
        "other"
      ]
    },
    "source_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "source_record_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "source_summary_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "source_decision_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "creator_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "created_by_node_id": {
      "type": "string",
      "minLength": 1
    },
    "assignee_user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "assignee_role": {
      "type": "string"
    },
    "assignment_type": {
      "type": "string",
      "enum": [
        "owner",
        "collaborator",
        "watcher",
        "reviewer"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "blocked",
        "completed",
        "closed",
        "cancelled"
      ]
    },
    "due_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "closed_at": {
      "type": "string",
      "format": "date-time"
    },
    "result_summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "confirm_required": {
      "type": "boolean"
    },
    "confirmed_by": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "confirmed_at": {
      "type": "string",
      "format": "date-time"
    },
    "blocked_reason": {
      "type": "string"
    },
    "cancel_reason": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "org_id",
    "task_title",
    "task_description",
    "source_type",
    "source_id",
    "creator_user_id",
    "created_by_node_id",
    "priority",
    "status",
    "confirm_required"
  ]
}
