{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automage.local/schemas/schema_v1_staff.json",
  "title": "AutoMage-2 MVP Staff Daily Report Schema",
  "description": "schema_v1_staff：Staff Agent 每日日报输出契约。用于员工日报提交、后端校验、Manager 汇总读取。",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "idRef": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confirm_status": {
          "type": "string",
          "enum": [
            "draft",
            "pending",
            "confirmed",
            "rejected",
            "revoked"
          ],
          "description": "人工确认状态"
        },
        "signed_by": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "signed_by_role": {
          "type": "string"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature_method": {
          "type": "string",
          "enum": [
            "manual_confirm",
            "im_confirm",
            "web_confirm",
            "api_confirm",
            "system"
          ]
        },
        "payload_hash": {
          "type": "string",
          "minLength": 1
        },
        "signature_value": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        }
      },
      "required": [
        "confirm_status",
        "signed_by",
        "signed_at",
        "signature_method",
        "payload_hash"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "artifact_type": {
          "type": "string",
          "enum": [
            "document",
            "code",
            "image",
            "link",
            "file",
            "table",
            "diagram",
            "prompt",
            "context",
            "config",
            "other"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "mime_type": {
          "type": "string"
        },
        "storage_type": {
          "type": "string",
          "enum": [
            "url",
            "file",
            "object_storage",
            "local_path",
            "text"
          ]
        },
        "version": {
          "type": "string"
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "artifact_type",
        "title"
      ]
    },
    "taskProgress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "task_title": {
          "type": "string"
        },
        "today_result": {
          "type": "string"
        },
        "previous_status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "completed",
            "closed",
            "cancelled"
          ]
        },
        "current_status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "completed",
            "closed",
            "cancelled"
          ]
        },
        "completion_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "need_follow_up": {
          "type": "boolean"
        },
        "blocked_reason": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        }
      },
      "required": [
        "task_id",
        "current_status"
      ]
    },
    "workProgressItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "item_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "item_type": {
          "type": "string",
          "enum": [
            "document",
            "code",
            "api",
            "database",
            "prompt",
            "context",
            "workflow",
            "test",
            "meeting",
            "decision",
            "operation",
            "other"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "blocked",
            "completed",
            "cancelled"
          ]
        },
        "evidence": {
          "type": "string"
        },
        "artifact_ids": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "uniqueItems": true
        },
        "artifact_links": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_module": {
          "type": "string"
        },
        "available_for_integration": {
          "type": "boolean"
        }
      },
      "required": [
        "title",
        "description",
        "status"
      ]
    },
    "issueItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issue_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "issue_title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "impact_scope": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "is_blocking": {
          "type": "boolean"
        },
        "need_support_from": {
          "type": "string"
        }
      },
      "required": [
        "issue_title",
        "description",
        "severity",
        "is_blocking"
      ]
    },
    "solutionItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "solution_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "issue_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "in_progress",
            "effective",
            "ineffective",
            "pending_verify"
          ]
        }
      },
      "required": [
        "description"
      ]
    },
    "planItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plan_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "expected_output": {
          "type": "string"
        },
        "related_task_id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      },
      "required": [
        "title",
        "priority"
      ]
    }
  },
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "schema_v1_staff"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "org_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "department_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "user_id": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "record_date": {
      "type": "string",
      "format": "date"
    },
    "task_progress": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/taskProgress"
      }
    },
    "work_progress": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workProgressItem"
      }
    },
    "issues_faced": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issueItem"
      }
    },
    "solution_attempt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/solutionItem"
      }
    },
    "need_support": {
      "type": "boolean"
    },
    "support_detail": {
      "type": "string"
    },
    "need_decision": {
      "type": "boolean",
      "default": false
    },
    "decision_detail": {
      "type": "string"
    },
    "next_day_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/planItem"
      }
    },
    "resource_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "work_hours": {
          "type": "number",
          "minimum": 0
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budget": {
          "type": "number",
          "minimum": 0
        },
        "materials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "other": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "related_task_ids": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "integer",
            "minimum": 1
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      },
      "uniqueItems": true
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "low"
    },
    "employee_comment": {
      "type": "string"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "timestamp",
    "org_id",
    "department_id",
    "user_id",
    "node_id",
    "record_date",
    "work_progress",
    "need_support",
    "next_day_plan",
    "risk_level",
    "signature"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "need_support": {
            "const": true
          }
        },
        "required": [
          "need_support"
        ]
      },
      "then": {
        "required": [
          "support_detail"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "need_decision": {
            "const": true
          }
        },
        "required": [
          "need_decision"
        ]
      },
      "then": {
        "required": [
          "decision_detail"
        ]
      }
    }
  ]
}
